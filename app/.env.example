# PUBLIC ENV VARS — Sepolia
# Static values below are the current Interfold/Enclave Sepolia deployment.
# Fill DAO + plugin addresses + deployment block from the `make deploy` output.

# General
NEXT_PUBLIC_DAO_ADDRESS=                                                  # from deploy output
NEXT_PUBLIC_TOKEN_ADDRESS=0xbAb3220FD04a193a192F07879673597Cd695Cb03      # FOLD (InterfoldToken)
NEXT_PUBLIC_ENCLAVE_FEE_TOKEN_ADDRESS=0x2721Cdf281d40744aD567cBf3e7100F60bcbAE79  # MockUSDC fee token

# Plugin addresses
# CRISP plugin -> PRIVATE (encrypted) proposals
NEXT_PUBLIC_CRISP_VOTING_PLUGIN_ADDRESS=                                  # from deploy output (index 0)
# TokenVoting plugin -> PUBLIC proposals (FOLD ERC20Votes token)
NEXT_PUBLIC_TOKEN_VOTING_PLUGIN_ADDRESS=                                  # from deploy output (index 1)

NEXT_PUBLIC_SECONDS_PER_BLOCK=12

# The block where the DAO/plugins were deployed (speeds up event queries)
NEXT_PUBLIC_PLUGIN_DEPLOYMENT_BLOCK=                                      # from deploy output
# The block FOLD (InterfoldToken) was deployed at — start of the delegate-list event scan
NEXT_PUBLIC_TOKEN_DEPLOYMENT_BLOCK=10939866

# Enclave — hosted CRISP server
NEXT_PUBLIC_CRISP_SERVER_URL="https://crisp-api.enclave.gg"

# Network and services
NEXT_PUBLIC_CHAIN_NAME=sepolia
NEXT_PUBLIC_WEB3_ENDPOINT=https://eth-sepolia.g.alchemy.com/v2/           # your Alchemy/Infura key

NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID="YOUR WALLET CONNECT PROJECT ID"

NEXT_PUBLIC_IPFS_ENDPOINTS="https://domain1/api,https://domain2/api/v0"
NEXT_PUBLIC_PINATA_JWT="..."

NEXT_PUBLIC_ETHERSCAN_API_KEY="OPTIONAL: ETHERSCAN API"
