# =============================================================================
# Target network: SEPOLIA (chain 11155111)
# Framework + plugin addresses below are researched & verified on-chain.
# Fill in PRIVATE_KEY, RPC_URL, and the CRISP params, then `cp .env.example .env`.
# =============================================================================

# NETWORK / ACCOUNT
PRIVATE_KEY="0x..."
RPC_URL="https://ethereum-sepolia-rpc.publicnode.com"

# OSx framework (Sepolia) — v1.4.0, verified live + authorized on the (upgraded) registry.
# NOTE: the v1.3.0 factories (0x7a62da7B / 0x07f49c49) are deprecated and revert with
# DaoUnauthorized on the in-place-upgraded registry — use the v1.4.0 ones below.
DAO_FACTORY_ADDRESS="0xB815791c233807D39b7430127975244B36C19C8e"
PLUGIN_REPO_FACTORY_ADDRESS="0x399Ce2a71ef78bE6890EB628384dD09D4382a7f0"

# Shared governance token (Sepolia). NOTE: on-chain symbol is "ENCL" (EnclaveToken),
# the address you provided as FOLD. It IS ERC20Votes/IVotes, so both plugins share it.
FOLD_TOKEN_ADDRESS="0xbAb3220FD04a193a192F07879673597Cd695Cb03"

# Aragon canonical TokenVoting PluginRepo (Sepolia). On-chain: latestRelease=1, buildCount=4.
# Build 4 = the v1.4 build, matching the frontend ABI.
TOKEN_VOTING_PLUGIN_REPO="0x424F4cA6FA9c24C03f2396DF0E96057eD11CF7dF"
TOKEN_VOTING_RELEASE="1"
TOKEN_VOTING_BUILD="4"

# Optional: after creating the DAO, transfer the Interfold contract's ownership to it.
# Interfold is Ownable2Step, so this only sets the DAO as PENDING owner — the DAO must then
# execute Interfold.acceptOwnership() via a governance proposal to finalize. The deployer
# (PRIVATE_KEY) must currently be the Interfold owner, or the step no-ops with a log.
TRANSFER_INTERFOLD_OWNERSHIP="false"
INTERFOLD_ADDRESS="0xCe087F31e20E2F76b6544A2E4A74D4557C8fDf77"

# Public (TokenVoting) governance settings. Ratios are ppm out of 1_000_000.
TV_VOTING_MODE="0"            # 0 Standard, 1 EarlyExecution, 2 VoteReplacement
TV_SUPPORT_THRESHOLD="500000" # > 50%
TV_MIN_PARTICIPATION="100000" # 10%
TV_MIN_DURATION="3600"        # seconds (>= protocol minimum)
TV_MIN_PROPOSER_VOTING_POWER="0"
TV_MIN_APPROVALS="0"

# CRISP (private) plugin install settings — consumed by Utils.readCrispEnv().
# ENCLAVE_ADDRESS must be the Interfold/Enclave coordinator that implements IEnclave,
# INCLUDING feeToken() — CrispVoting.initialize calls enclave.feeToken().
# Sepolia Interfold is 0xCe087F31e20E2F76b6544A2E4A74D4557C8fDf77, but the CURRENTLY
# DEPLOYED build predates feeToken() and will revert. Deploy the current
# enclave/packages/interfold-contracts Interfold.sol (which has feeToken) and set it here.
ENCLAVE_ADDRESS="0xCe087F31e20E2F76b6544A2E4A74D4557C8fDf77"
CRISP_PROGRAM_ADDRESS="0x23CBb3Bac32Ca3282c916da6d21F5f69D0865050"
MINIMUM_PARTICIPATION="50"
MINIMUM_DURATION="0"
MINIMUM_PROPOSER_VOTING_POWER="1"
COMMITTEE_SIZE="0"
PARAM_SET="0"
COMPUTE_PROVIDER_PARAMS="0x7b226e616d65223a225249534330222c22706172616c6c656c223a66616c73652c2262617463685f73697a65223a347d"
